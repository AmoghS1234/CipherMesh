<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="?attr/colorWindowBg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create New Group"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?attr/colorTextPrimary"
        android:layout_marginBottom="8dp"
        app:drawableStartCompat="@android:drawable/ic_menu_today"
        android:drawablePadding="8dp"
        app:drawableTint="?attr/colorTextPrimary"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter a name for your new password group."
        android:textColor="?attr/colorTextSecondary"
        android:textSize="14sp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Group Name:"
        android:textColor="?attr/colorTextPrimary"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/CipherMesh.Input"
        android:layout_marginBottom="24dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/dialogInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g., Work, Personal, Banking..."
            android:textColor="?attr/colorTextPrimary" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dialogCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="?attr/colorTextPrimary"
            app:backgroundTint="?attr/colorSurface"
            app:strokeColor="?attr/colorInputBorder"
            app:strokeWidth="1dp"
            android:layout_marginEnd="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dialogOk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Group"
            android:textColor="@color/white"
            app:backgroundTint="?attr/colorActionPrimary" />
    </LinearLayout>
</LinearLayout>